{
  "permissions": {
    "allow": [
      "*"
    ],
    "deny": [
      "Bash(git commit *)",
      "Bash(git commit)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Edit(**/.env)",
      "Edit(**/*.pem)",
      "Write(**/.env)",
      "Write(**/*.pem)"
    ]
  },
  "autoMemoryEnabled": true,
  "enabledMcpjsonServers": [
    "playwright",
    "postman",
    "figma"
  ],
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jose/projects/automation/.claude/scripts/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jose/projects/automation/.claude/scripts/pre-write-validate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jose/projects/automation/.claude/scripts/auto-review.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jose/projects/automation/.claude/scripts/subagent-log.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jose/projects/automation/.claude/scripts/subagent-log.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jose/projects/automation/.claude/scripts/session-review.sh"
          }
        ]
      }
    ]
  }
}
