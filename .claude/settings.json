{
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [],
    "deny": [
      "Bash(git commit *)",
      "Bash(git commit)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git reset --hard*)",
      "Bash(git reset --soft*)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git rebase*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Edit(**/.env)",
      "Edit(**/*.pem)",
      "Write(**/.env)",
      "Write(**/*.pem)"
    ]
  },
  "autoMemoryEnabled": true,
  "enabledMcpjsonServers": [
    "playwright",
    "postman",
    "figma"
  ],
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/session-start.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/pre-write-validate.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/lock-selectors.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/auto-review.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/unlock-selectors.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/subagent-log.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/subagent-log.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/session-review.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
