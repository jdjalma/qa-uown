{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent",
      "WebFetch",
      "WebSearch",
      "Task",
      "mcp__playwright__*",
      "mcp__postman__*",
      "mcp__figma__*",
      "mcp__ide__*"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git reset --soft*)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git rebase*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Edit(**/.env)",
      "Edit(**/*.pem)",
      "Write(**/.env)",
      "Write(**/*.pem)"
    ]
  },
  "autoMemoryEnabled": true,
  "enabledMcpjsonServers": [
    "playwright",
    "postman",
    "figma"
  ],
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/session-start.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/pre-write-validate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/lock-selectors.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/auto-review.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/unlock-selectors.sh\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/subagent-log.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/subagent-log.sh\""
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/scripts/verify-skills-loaded.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/session-review.sh\""
          }
        ]
      }
    ]
  }
}
