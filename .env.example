# ═══════════════════════════════════════════════════════════════
# fintech-playwright — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# STRUCTURE:
#   .env          → Shared/cross-environment (API keys, DB, tokens, email)
#   .env.sandbox  → Sandbox-specific (URLs, credentials)
#   .env.qa1      → QA1-specific
#   .env.qa2      → QA2-specific
#   .env.stg      → Staging-specific
#   .env.dev1     → Dev1-specific
#   .env.dev2     → Dev2-specific
#   .env.dev3     → Dev3-specific
#
# LOADING ORDER: .env (base) → .env.{env} (overrides)
# The test's `env` parameter (e.g. testData[].env = 'dev3') determines
# which .env.{env} file is loaded. Values in .env.{env} override .env.
#
# TO SWITCH ENVIRONMENTS: only change `env` in the test's testData array.
# No need to edit .env — credentials/URLs are per-environment.
# ═══════════════════════════════════════════════════════════════

# ─── Base .env (shared) ───────────────────────────────────────

TEST_ENV=sandbox

# Email (shared Gmail for OTP verification)
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# API Keys (cross-environment)
UOWN_API_AUTHORIZATION=your_api_authorization_key
UOWN_API_KEY=your_api_key
ORIGINATION_TOKEN=your_origination_token
PAYPAIR_TOKEN=your_paypair_jwt_token
FIVE9_TMS_API_KEY=your_five9_tms_key

# GitLab
GITLAB_TOKEN=your_gitlab_pat
GITLAB_URL=https://gitlab.com

# Kount (optional)
KOUNT_CLIENT_ID=
KOUNT_API_KEY_B64=

# Credit Cards (shared test data)
CC_SUBSCRIPTION_CARD_NUMBER=6011000993026909
CC_SUBSCRIPTION_CVV=996
CC_SUBSCRIPTION_EXPIRATION_DATE=12/28
SERV_CC_NUMBER=5146315000000055
SERV_CC_SECURITY_CODE=998
SERV_CC_EXPIRATION_DATE=12/28

# Database per-environment (JDBC format, auto-converted to node-pg)
UOWN_DB_URL_QA1=jdbc:postgresql://host:port/db
UOWN_DB_USER_QA1=db_user
UOWN_DB_PASS_QA1=db_password
UOWN_DB_URL_SBX=jdbc:postgresql://host:port/db
UOWN_DB_USER_SBX=db_user
UOWN_DB_PASS_SBX=db_password
# ... add more per-environment DB configs as needed

# ─── Per-environment .env.{env} (example) ─────────────────────
# Each .env.{env} file contains:
#
# # Portal URLs
# ORIGINATION_URL=https://origination-{env}.uownleasing.com/
# SERVICING_URL=https://svc-website-{env}.uownleasing.com/
# WEBSITE_URL=https://website-{env}.uownleasing.com/
# AMS_URL=https://ams-website-{env}.uownleasing.com/
#
# # Portal Credentials (may differ per environment)
# ADMIN_USERNAME=superadmin
# ADMIN_PASSWORD=admin
# MANAGER_USERNAME=manager
# MANAGER_PASSWORD=your_password
# READONLY_USERNAME=readonly
# READONLY_PASSWORD=your_password
# MERCHANT_USERNAME=merchant_user     # differs: sandbox=wjunio.gow, others=AutotestMerchant
# MERCHANT_PASSWORD=merchant_password
# SUPERVISOR_USERNAME=AutotestSupervisor
# SUPERVISOR_PASSWORD=your_password
# AGENT_USERNAME=AutotestAgent
# AGENT_PASSWORD=your_password
