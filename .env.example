# ═══════════════════════════════════════════════════════════════
# fintech-playwright — Configuração de Ambiente
# ═══════════════════════════════════════════════════════════════
#
# ARQUIVO ÚNICO: toda a configuração fica em .env
# Não existem mais arquivos .env.{env} separados.
#
# ENVS VÁLIDOS: sandbox, qa1, qa2, stg, dev1, dev2, dev3
# Um env inválido lança erro em ConfigEnvironment.
#
# VARIÁVEL DE AMBIENTE (não vai no .env — é variável de runtime):
#   ENV=qa1 npx playwright test   ← linha de comando
#   ENV=sandbox                   ← default quando não definido
# No CI, ENV é injetado automaticamente pelo job via spec.inputs.
#
# RESOLUÇÃO DE CREDENCIAIS (ordem de prioridade):
#   1. {ENV_UPPER}_{ROLE}_USERNAME  — ex: QA1_ADMIN_USERNAME
#   2. DEFAULT_{ROLE}_USERNAME      — padrão para todos os envs
#
# RESOLUÇÃO DE EMAIL:
#   {ENV_UPPER}_EMAIL → EMAIL
#
# RESOLUÇÃO DE URL (só necessário se o padrão NÃO se aplica):
#   {ENV_UPPER}_ORIGINATION_URL → ORIGINATION_URL → auto-gerado
#   Padrão auto-gerado: https://{portal}-{env}.uownleasing.com/
#
# PARA ADICIONAR UM NOVO AMBIENTE:
#   - Se usa os mesmos defaults → nenhuma linha nova necessária
#   - Se tem credenciais diferentes → adicionar {ENV_UPPER}_* nas exceções
# ═══════════════════════════════════════════════════════════════

# ─── Email (padrão) ───────────────────────────────────────────
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# ─── API Keys (cross-environment) ────────────────────────────
UOWN_API_AUTHORIZATION=your_api_authorization_key
UOWN_API_KEY=your_api_key
ORIGINATION_TOKEN=your_origination_token
PAYPAIR_TOKEN=your_paypair_jwt_token
FIVE9_TMS_API_KEY=your_five9_tms_key

# ─── GitLab ───────────────────────────────────────────────────
GITLAB_TOKEN=your_gitlab_pat
GITLAB_URL=https://gitlab.com

# ─── Kount (opcional) ─────────────────────────────────────────
KOUNT_CLIENT_ID=
KOUNT_API_KEY_B64=

# ─── Cartões de crédito de teste ──────────────────────────────
CC_SUBSCRIPTION_CARD_NUMBER=6011000993026909
CC_SUBSCRIPTION_CVV=996
CC_SUBSCRIPTION_EXPIRATION_DATE=12/28
SERV_CC_NUMBER=5146315000000055
SERV_CC_SECURITY_CODE=998
SERV_CC_EXPIRATION_DATE=12/28

# ─── Banco de dados por ambiente ──────────────────────────────
# Padrão: UOWN_DB_URL_{SUFFIX}, UOWN_DB_USER_{SUFFIX}, UOWN_DB_PASS_{SUFFIX}
# Sufixos: qa1=QA1, qa2=QA2, stg=STG, dev1=DEV1, dev2=DEV2, dev3=DEV3, sandbox=SBX
UOWN_DB_URL_QA1=jdbc:postgresql://host:port/db
UOWN_DB_USER_QA1=db_user
UOWN_DB_PASS_QA1=db_password
UOWN_DB_URL_QA2=jdbc:postgresql://host:port/db
UOWN_DB_USER_QA2=db_user
UOWN_DB_PASS_QA2=db_password
UOWN_DB_URL_STG=jdbc:postgresql://host:port/db
UOWN_DB_USER_STG=db_user
UOWN_DB_PASS_STG=db_password
UOWN_DB_URL_DEV1=jdbc:postgresql://host:port/db
UOWN_DB_USER_DEV1=db_user
UOWN_DB_PASS_DEV1=db_password
UOWN_DB_URL_SBX=jdbc:postgresql://host:port/db
UOWN_DB_USER_SBX=db_user
UOWN_DB_PASS_SBX=db_password
# Adicionar DEV2/DEV3 conforme necessário:
# UOWN_DB_URL_DEV2=jdbc:postgresql://host:port/db
# UOWN_DB_USER_DEV2=db_user
# UOWN_DB_PASS_DEV2=db_password

# ─── Credenciais padrão (aplicadas a todos os envs) ──────────
DEFAULT_ADMIN_USERNAME=superadmin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_MANAGER_USERNAME=manager
DEFAULT_MANAGER_PASSWORD=P@ssw0rdu0wn
DEFAULT_READONLY_USERNAME=readonly
DEFAULT_READONLY_PASSWORD=P@ssw0rdu0wn
DEFAULT_MERCHANT_USERNAME=AutotestMerchant
DEFAULT_MERCHANT_PASSWORD=P@ssw0rdu0wn
DEFAULT_SUPERVISOR_USERNAME=jmendes.gow
DEFAULT_SUPERVISOR_PASSWORD=Uown_gow
DEFAULT_AGENT_USERNAME=AutotestAgent
DEFAULT_AGENT_PASSWORD=P@ssw0rdu0wn

# ─── Exceções por ambiente (só o que difere do padrão) ───────

# QA1: role "admin" usa a conta "manager" (não superadmin)
QA1_ADMIN_USERNAME=manager
QA1_ADMIN_PASSWORD=P@ssw0rdu0wn

# Sandbox: merchant usa conta diferente do AutotestMerchant
SANDBOX_MERCHANT_USERNAME=wjunio.gow
SANDBOX_MERCHANT_PASSWORD=your_sandbox_merchant_password

# STG: usa conta de email separada para OTP
STG_EMAIL=your_stg_email@test.com
STG_EMAIL_PASSWORD=your_stg_app_password

# ─── LOS Partner API (merchant bearer token auth — Task #482) ─
LOS_PARTNER_USERNAME=
LOS_PARTNER_PASSWORD=

# ─── Exemplo: adicionar novo ambiente com exceção ─────────────
# Novo env "dev4" com merchant diferente:
# DEV4_MERCHANT_USERNAME=DevMerchant
# DEV4_MERCHANT_PASSWORD=dev_password
#
# Novo env "uat" com URL não-padrão:
# UAT_ORIGINATION_URL=https://origination-uat-custom.uownleasing.com/
